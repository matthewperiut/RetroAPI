{
	"schemaVersion": 1,
	"id": "retroapi-registration",
	"version": "${version}",
	"name": "RetroAPI Registration",
	"description": "Block and item registration, textures, storage, networking, and lang.",
	"authors": ["periut"],
	"license": "MIT",
	"environment": "*",
	"entrypoints": {
		"init": [
			"com.periut.retroapi.RetroAPI"
		],
		"client-init": [
			"com.periut.retroapi.client.RetroAPIClient"
		],
		"server-init": [
			"com.periut.retroapi.server.RetroAPIServer"
		]
	},
	"accessWidener": "retroapi.registration.accesswidener",
	"mixins": [
		"retroapi.registration.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.17.3",
		"minecraft": ">=1.0.0-beta.3 <=1.0.0-beta.3.1",
		"osl-entrypoints": ">=0.4.0",
		"osl-lifecycle-events": ">=0.5.0",
		"osl-networking": ">=0.9.0-"
	}
}
