{
	"schemaVersion": 1,
	"id": "retroapi",
	"version": "${version}",
	"name": "RetroAPI",
	"description": "Block, Item, Recipe, Entity, Dimension Registration API for Legacy Minecraft. Supports Ornithe and Babric. Optionally Works with StationAPI.",
	"authors": ["Slainlight"],
	"license": "MIT",
	"icon": "assets/retroapi/icon.png",
	"environment": "*",
	"entrypoints": {
		"init": [
			"com.periut.retroapi.RetroAPI"
		],
		"client-init": [
			"com.periut.retroapi.client.RetroAPIClient"
		],
		"server-init": [
			"com.periut.retroapi.server.RetroAPIServer"
		]
	},
	"accessWidener": "retroapi.accesswidener",
	"mixins": [
		"retroapi.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.17.3",
		"minecraft": "1.0.0-beta.7.3",
		"osl-entrypoints": ">=0.4.0",
		"osl-lifecycle-events": ">=0.5.0",
		"osl-networking": ">=0.9.0-"
	}
}
